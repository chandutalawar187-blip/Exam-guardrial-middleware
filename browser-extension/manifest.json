{
  "manifest_version": 3,
  "name": "ExamGuardrail Sentinel",
  "version": "3.0.0",
  "description": "Exam integrity monitoring — Self-contained proctoring sentinel",

  "permissions": [
    "scripting",
    "tabs",
    "windows",
    "storage",
    "activeTab",
    "webNavigation"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://localhost:5173/*",
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "ExamGuardrail Sentinel"
  }
}