# ExamGuardrail Environment Variables
# Copy this to .env and fill in your actual values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key-here

# Admin credentials for dashboard
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secret-password

# Optional: Claude AI for analyzing violations
ANTHROPIC_API_KEY=

# Native agent scanner settings
NATIVE_AGENT_ENABLED=true
NATIVE_AGENT_BLOCK=true
NATIVE_AGENT_INTERVAL=3

# Monitoring-only mode (no database routes)
MONITORING_ONLY=false

# CORS origins
CORS_ORIGINS=["*"]
