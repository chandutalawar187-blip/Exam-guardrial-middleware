{
  "buildCommand": "npm run build --prefix dashboard",
  "outputDirectory": "dashboard/dist",
  "framework": "vite",
  "functions": {
    "api/index.py": {
      "runtime": "python3.12",
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "ADMIN_USERNAME": "@admin_username",
    "ADMIN_PASSWORD": "@admin_password"
  }
}
